{
  "name": "voco",
  "version": "2026.0.21",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/desktop",
    "build": "npm run build -w apps/desktop",
    "lint": "npm run lint -w apps/desktop",
    "check": "npm run check --workspaces --if-present",
    "test": "npm run test:owned-preedit && node scripts/report-cursor-streaming-trace.test.mjs && node scripts/report-dictation-baseline-config.test.mjs && node scripts/reset-cursor-streaming-trace.test.mjs && npm run test --workspaces --if-present",
    "test:owned-preedit": "PYTHONDONTWRITEBYTECODE=1 /usr/bin/python3 apps/desktop/src-tauri/resources/voco_ibus_ownership_test.py && PYTHONDONTWRITEBYTECODE=1 /usr/bin/python3 apps/desktop/src-tauri/resources/voco_ibus_protocol_test.py && PYTHONDONTWRITEBYTECODE=1 /usr/bin/python3 apps/desktop/src-tauri/resources/voco_ibus_engine_test.py",
    "test:private-ibus": "PYTHONDONTWRITEBYTECODE=1 bash scripts/test-private-ibus-engine.sh",
    "test:captured-dictation": "CARGO_BUILD_JOBS=${CARGO_BUILD_JOBS:-2} cargo build --quiet --locked --manifest-path apps/desktop/src-tauri/Cargo.toml --example preview_replay_worker && npm run test:captured-dictation -w apps/desktop",
    "verify:versions": "node scripts/check-version-consistency.mjs",
    "verify:devops": "bash ./scripts/check-devops.sh",
    "verify:security": "npm audit --audit-level=moderate",
    "smoke:realtime": "node scripts/realtime-protocol-smoke.mjs",
    "rehearse:release": "bash ./scripts/rehearse-release.sh",
    "report:linux-runtime": "bash ./scripts/report-linux-runtime.sh",
    "report:cursor-streaming": "node scripts/report-cursor-streaming-trace.mjs",
    "report:dictation-baseline": "node scripts/report-dictation-baseline-config.mjs",
    "reset:cursor-streaming-trace": "node scripts/reset-cursor-streaming-trace.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
