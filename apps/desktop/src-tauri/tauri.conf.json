{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri2-schema/main/tauri.conf.json",
  "productName": "VOCO",
  "version": "2026.0.21",
  "identifier": "com.sergiopesch.voco",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:frontend",
    "beforeBuildCommand": "npm run build:frontend"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VOCO",
        "width": 1,
        "height": 1,
        "x": -100,
        "y": -100,
        "resizable": false,
        "alwaysOnTop": false,
        "decorations": false,
        "transparent": true,
        "skipTaskbar": true,
        "visible": true,
        "center": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://api.github.com https://api.openai.com wss://api.openai.com; media-src 'self' mediastream:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "category": "Utility",
    "shortDescription": "A voice-native interface layer designed for speed and precision",
    "longDescription": "VOCO is a Linux desktop dictation tool built for low-friction voice capture, local-first speech processing, and fast insertion into the app you are already using. It stays lightweight in the tray, guides microphone setup on first launch, and keeps Linux-specific behavior explicit instead of hiding platform constraints.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "linux": {
      "appimage": {
        "files": {
          "/usr/share/metainfo/com.sergiopesch.voco.metainfo.xml": "../../../packaging/tauri/com.sergiopesch.voco.metainfo.xml"
        }
      },
      "deb": {
        "desktopTemplate": "../../../packaging/tauri/VOCO.desktop",
        "depends": [
          "ibus",
          "python3",
          "gir1.2-ibus-1.0",
          "python3-gi"
        ],
        "files": {
          "/usr/share/metainfo/com.sergiopesch.voco.metainfo.xml": "../../../packaging/tauri/com.sergiopesch.voco.metainfo.xml",
          "/usr/share/ibus/component/voco.xml": "../../../packaging/ibus/voco.xml",
          "/usr/libexec/voco-ibus-engine": "../../../packaging/ibus/voco-ibus-engine",
          "/usr/lib/voco/ibus/voco_ibus_engine.py": "resources/voco_ibus_engine.py",
          "/usr/lib/voco/ibus/voco_ibus_ownership.py": "resources/voco_ibus_ownership.py",
          "/usr/lib/voco/ibus/voco_ibus_protocol.py": "resources/voco_ibus_protocol.py"
        }
      }
    }
  },
  "plugins": {
    "global-shortcut": null
  }
}
